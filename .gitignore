```gitignore
# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Dependencies
node_modules/
vendor/

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
*.tmp

# PHP
*.phar

# Original rules preserved
*.log
```